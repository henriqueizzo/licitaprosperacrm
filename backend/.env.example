# Chave da API Anthropic (criar em https://console.anthropic.com -> API Keys)
ANTHROPIC_API_KEY=

# Token da API ConLicitação (solicitar ao suporte ConLicitação como assinante)
CONLICITACAO_TOKEN=

# Banco de dados (SQLite local por padrão; trocar por postgresql+psycopg://... na nuvem)
DATABASE_URL=sqlite:///./licitaprospera.db

# Coleta automática a cada N horas (0 = desligado, use POST /api/pipeline/executar)
COLETA_INTERVALO_HORAS=6

# Score mínimo (0-100) para criar oportunidade automaticamente no CRM
SCORE_MINIMO_OPORTUNIDADE=60

# Admin inicial: criado automaticamente no 1º startup se não existir nenhum usuário.
# TROQUE A SENHA no primeiro acesso (menu "Trocar senha" no app).
ADMIN_EMAIL=admin@exemplo.com
ADMIN_SENHA_INICIAL=troque-me

# Cookie de sessão com Secure (exige HTTPS). Deixe false no PC local; true na nuvem.
COOKIE_SECURE=false

# Validade da sessão de login, em dias
SESSAO_DIAS=7
